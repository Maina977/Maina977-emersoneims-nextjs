# EMERSON EIMS Building Suite Pro - Configuration Template
# Copy to .env and edit for your environment. Do NOT commit .env (it is gitignored).

# ----- Server -----
# Host to bind to. Use 127.0.0.1 for localhost-only, 0.0.0.0 only if you
# intend to expose the app AND it's behind a reverse proxy with TLS.
EIMS_HOST=127.0.0.1
EIMS_PORT=5000

# Waitress worker threads (used by run_production.py).
EIMS_THREADS=8

# Flask debug mode. MUST remain 0 in production.
# Acceptable values: 0, 1, true, false, yes, no.
EIMS_DEBUG=0

# ----- Uploads & limits -----
# Hard cap on request body size (megabytes). Prevents DoS via huge uploads.
EIMS_MAX_UPLOAD_MB=10

# Where user uploads, FX cache, audit log, and projects.db are stored.
EIMS_UPLOAD_FOLDER=./uploads

# ----- CORS -----
# Comma-separated list of allowed cross-origin sites. Leave empty for
# same-origin only (default, safest).
# Example: EIMS_CORS_ORIGINS=https://app.example.com,https://admin.example.com
EIMS_CORS_ORIGINS=

# ----- Rate limiting -----
EIMS_RATELIMIT_PER_MINUTE=60
EIMS_RATELIMIT_BURST=20

# ----- Versioning -----
EIMS_VERSION=2026.04
