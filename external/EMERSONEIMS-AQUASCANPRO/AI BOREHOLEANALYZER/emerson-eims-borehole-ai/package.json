{
  "name": "ai-borehole-analyzer",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "vite --config ai-borehole-analyzer/vite.config.ts",
    "build": "npm run typecheck && vite build --config ai-borehole-analyzer/vite.config.ts",
    "preview": "vite preview --config ai-borehole-analyzer/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ai-borehole-analyzer/src --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint ai-borehole-analyzer/src --ext .ts,.tsx --fix",
    "validate": "npm run typecheck && npm run build",
    "validate:all": "node scripts/validate-all.mjs",
    "precommit": "npm run typecheck && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@tensorflow-models/mobilenet": "^2.1.0",
    "@tensorflow/tfjs": "^4.15.0",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "exifr": "^7.1.3",
    "file-saver": "^2.0.5",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "playwright": "^1.59.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "typescript": "^5.0.0",
    "vite": "^6.4.2"
  },
  "lint-staged": {
    "ai-borehole-analyzer/src/**/*.{ts,tsx}": [
      "tsc --noEmit --project tsconfig.json"
    ]
  }
}
