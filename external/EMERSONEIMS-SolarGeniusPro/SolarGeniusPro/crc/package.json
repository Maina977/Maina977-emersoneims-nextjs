{
  "name": "solargenius-pro",
  "version": "3.0.0",
  "description": "World's Most Advanced Solar AI Platform - Complete Edition",
  "main": "server/index.js",
  "scripts": {
    "syntax-check": "node scripts/syntax-check.mjs",
    "predev": "node scripts/syntax-check.mjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "start": "concurrently \"npm run server\" \"npm run dev\"",
    "mobile": "cd mobile-app && npm start",
    "mobile:android": "cd mobile-app && npm run android",
    "mobile:ios": "cd mobile-app && npm run ios",
    "docker:up": "docker-compose -f docker/docker-compose.yml up",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "test": "jest --testPathPattern=tests",
    "test:watch": "jest --watch --testPathPattern=tests",
    "lint": "eslint src --ext ts,tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "build:mobile": "cd mobile-app && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@react-three/drei": "^9.92.0",
    "@react-three/fiber": "^8.13.0",
    "@tensorflow-models/body-segmentation": "^1.0.0",
    "@tensorflow/tfjs": "^4.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/styled-components": "^5.1.36",
    "axios": "^1.4.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.0",
    "chart.js": "^4.3.0",
    "cors": "^2.8.5",
    "date-fns": "^2.30.0",
    "docx": "^8.5.0",
    "dotenv": "^16.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.0",
    "express-rate-limit": "^6.7.0",
    "framer-motion": "^10.18.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.6.0",
    "leaflet": "^1.9.4",
    "mqtt": "^5.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.0",
    "nodemailer": "^6.9.0",
    "papaparse": "^5.4.0",
    "prisma": "^5.0.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.0",
    "react-helmet-async": "^2.0.0",
    "react-hook-form": "^7.45.0",
    "react-hot-toast": "^2.4.0",
    "react-icons": "^4.10.0",
    "react-leaflet": "^5.0.0",
    "react-query": "^3.39.0",
    "react-router-dom": "^6.14.0",
    "recharts": "^2.7.0",
    "redis": "^4.6.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.6.0",
    "socket.io-client": "^4.6.0",
    "styled-components": "^6.4.1",
    "tesseract.js": "^5.0.0",
    "three": "^0.155.0",
    "typescript": "^5.0.0",
    "winston": "^3.9.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zustand": "^4.3.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
