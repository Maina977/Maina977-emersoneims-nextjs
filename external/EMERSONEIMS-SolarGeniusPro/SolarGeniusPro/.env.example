# ============================================
# SOLARGENIUS PRO - ENVIRONMENT VARIABLES
# Copy to .env and fill in your values
# ============================================

# APP CONFIGURATION
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
APP_NAME=SolarGeniusPro

# DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/solargenius
DATABASE_POOL_SIZE=20

# REDIS (Caching & Queues)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT AUTHENTICATION
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_EXPIRY=3600
JWT_REFRESH_EXPIRY=604800

# NASA POWER API
NASA_POWER_API_URL=https://power.larc.nasa.gov/api/temporal/daily/point
NASA_API_KEY=your-nasa-api-key

# GOOGLE SERVICES
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_EARTH_ENGINE_API_KEY=your-google-earth-engine-key
GOOGLE_CLOUD_PROJECT=your-gcp-project

# USGS LIDAR (OpenTopography)
LIDAR_API_URL=https://portal.opentopography.org/API/globaldem
LIDAR_API_KEY=your-lidar-api-key

# OPENWEATHER
OPENWEATHER_API_KEY=your-openweather-api-key

# M-PESA (Daraja API)
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_PASSKEY=your-mpesa-passkey
MPESA_SHORTCODE=174379
MPESA_ENVIRONMENT=sandbox

# FLUTTERWAVE
FLUTTERWAVE_PUBLIC_KEY=your-flutterwave-public-key
FLUTTERWAVE_SECRET_KEY=your-flutterwave-secret-key
FLUTTERWAY_ENCRYPTION_KEY=your-flutterwave-encryption-key

# PAYSTACK
PAYSTACK_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# OPENAI (AI Chat & Assistant)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# EMAIL (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@solargenius.com

# CLOUD STORAGE (AWS S3 / DigitalOcean Spaces)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
AWS_BUCKET_NAME=solargenius-assets

# CDN
CDN_URL=https://cdn.solargenius.com

# SENTRY (Error Tracking)
SENTRY_DSN=your-sentry-dsn

# LOGGING
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# MULTI-TENANCY
TENANCY_ENABLED=true
DEFAULT_TENANT_ID=emerson-eims

# OFFLINE MODE
OFFLINE_SYNC_INTERVAL=300000
OFFLINE_CACHE_SIZE=100

# FEATURE FLAGS
ENABLE_AI_ADVISOR=true
ENABLE_VOICE_ASSISTANT=true
ENABLE_DIGITAL_TWIN=true
ENABLE_MARKET_INTELLIGENCE=true