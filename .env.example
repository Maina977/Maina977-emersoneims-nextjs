# ============================================================================
# EMERSONEIMS SOLARGENIUS PRO - PRODUCTION ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in your actual credentials
# ============================================================================

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://www.emersoneims.com
WORDPRESS_SITE_URL=https://www.emersoneims.com
WORDPRESS_API_URL=https://www.emersoneims.com/wp-json/wp/v2

# WordPress Integration (optional)
WORDPRESS_INTEGRATION=false
STATIC_EXPORT=false

# Analytics (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ═══════════════════════════════════════════════════════════════════
# SEO VERIFICATION CODES
# ═══════════════════════════════════════════════════════════════════
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code
NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-verification-code
NEXT_PUBLIC_YANDEX_VERIFICATION=your-yandex-verification-code
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id

# Node Environment
NODE_ENV=production

# ═══════════════════════════════════════════════════════════════════
# GENERATOR ORACLE — LOCAL AI STACK (Track 2 readiness)
# Generator Oracle's diagnostic path is local-only by design. NO paid AI
# is used in the live diagnostic surfaces (ai-visual-diagnose,
# expert-chat, ai-diagnose). When the local stack is unset/unreachable,
# the routes return AI_UNAVAILABLE and the UI shows the honest unavailable
# notice — they do NOT silently fall back to a cloud model.
# ═══════════════════════════════════════════════════════════════════

# Ollama HTTP base — must serve Qwen2.5 (text) and Qwen2.5-VL (vision).
# Examples:
#   self-host on a GPU box reachable via Cloudflare Tunnel:
#     LOCAL_AI_BASE_URL=https://ollama.your-domain.com
#   internal VPC host (only if your Next.js runtime can reach it):
#     LOCAL_AI_BASE_URL=http://oracle-ai.internal:11434
LOCAL_AI_BASE_URL=

# Ollama model tags. Override per deployment.
LOCAL_AI_TEXT_MODEL=qwen2.5:7b-instruct
LOCAL_AI_VISION_MODEL=qwen2.5vl:7b

# PaddleOCR sidecar (separate HTTP service: POST /ocr -> { text, lines }).
# Leave unset to disable OCR — the visual diagnose pipeline still runs but
# without OCR-extracted nameplate / fault-code text.
LOCAL_AI_OCR_URL=

# Local retrieval / vector store sidecar
# (POST /query { text, k, filter? } -> { hits: [{ id, source, snippet, score }] }).
# Leave unset to disable retrieval — diagnoses will be labelled "generic".
LOCAL_AI_RETRIEVAL_URL=

# Tuning
LOCAL_AI_TIMEOUT_MS=60000
LOCAL_AI_MAX_TOKENS=4096

# ─────────────────────────────────────────────────────────────────
# GEMINI FALLBACK PROVIDER (free, hosted, multimodal)
# When LOCAL_AI_BASE_URL is unset AND GEMINI_API_KEY is set, the same
# call surface (ollamaChat / ollamaVision / health probe) transparently
# routes through Google Gemini. This lets the AI Analyzer, AI Chat and
# AI Visual Diagnostic work in production without self-hosting Ollama.
# Get a free key at https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_MS=60000
GEMINI_MAX_TOKENS=4096

# Kill-switch — any truthy value makes every Oracle AI surface render the
# AIUnavailableNotice synchronously and refuses POSTs at the route level.
NEXT_PUBLIC_GENERATOR_ORACLE_AI_DISABLED=
GENERATOR_ORACLE_AI_DISABLED=

# DEPRECATED — kept ONLY behind an explicit non-diagnostic feature flag,
# off by default. Cloud AI is NEVER used in core Generator Oracle
# diagnosis. This var must remain unset in any deployment that runs the
# diagnostic path.
GENERATOR_ORACLE_CLOUD_FALLBACK=false
ANTHROPIC_API_KEY=
CLAUDE_MODEL=

# ═══════════════════════════════════════════════════════════════════
# API SECURITY
# ═══════════════════════════════════════════════════════════════════
ADMIN_API_KEY=your-secure-admin-api-key-here
API_KEY=your-api-key-here

# ═══════════════════════════════════════════════════════════════════
# NASA POWER API (Free - No key required)
# https://power.larc.nasa.gov/docs/services/api/
# ═══════════════════════════════════════════════════════════════════
NASA_POWER_API_URL=https://power.larc.nasa.gov/api/temporal/daily/point

# ═══════════════════════════════════════════════════════════════════
# GOOGLE EARTH ENGINE
# https://earthengine.google.com/ - Apply for access
# ═══════════════════════════════════════════════════════════════════
GOOGLE_EARTH_ENGINE_PROJECT_ID=your-project-id
GOOGLE_EARTH_ENGINE_PRIVATE_KEY=your-private-key-json-string
GOOGLE_EARTH_ENGINE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# ═══════════════════════════════════════════════════════════════════
# OPENWEATHERMAP API
# https://openweathermap.org/api - Free tier: 1000 calls/day
# ═══════════════════════════════════════════════════════════════════
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# ═══════════════════════════════════════════════════════════════════
# ELEVATION / LIDAR DATA
# https://www.opentopodata.org/ (Free) or Google Elevation API
# ═══════════════════════════════════════════════════════════════════
OPEN_TOPO_DATA_URL=https://api.opentopodata.org/v1/srtm30m
GOOGLE_ELEVATION_API_KEY=your-google-elevation-api-key

# ═══════════════════════════════════════════════════════════════════
# M-PESA DARAJA API (Safaricom Kenya)
# https://developer.safaricom.co.ke/
# ═══════════════════════════════════════════════════════════════════
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-lipa-na-mpesa-passkey
MPESA_SHORTCODE=174379
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://your-domain.com/api/payments/mpesa/callback

# ═══════════════════════════════════════════════════════════════════
# FLUTTERWAVE API
# https://developer.flutterwave.com/
# ═══════════════════════════════════════════════════════════════════
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxx
FLUTTERWAVE_ENCRYPTION_KEY=your-encryption-key
FLUTTERWAVE_WEBHOOK_SECRET=your-webhook-secret

# ═══════════════════════════════════════════════════════════════════
# PAYSTACK API
# https://paystack.com/docs/api/
# ═══════════════════════════════════════════════════════════════════
PAYSTACK_PUBLIC_KEY=pk_test_xxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxx
PAYSTACK_WEBHOOK_SECRET=your-webhook-secret

# ═══════════════════════════════════════════════════════════════════
# EMAIL NOTIFICATIONS (SMTP) — EmersonEIMS OWN mail server
# This is the PRIMARY lead channel: /api/contact sends every enquiry from your
# own mailbox (info@emersoneims.com) to the team. Set these 5 in Vercel:
#   SMTP_HOST=mail.emersoneims.com
#   SMTP_PORT=465                 (use 587 if your host requires STARTTLS)
#   SMTP_USER=info@emersoneims.com
#   SMTP_PASSWORD=<the info@ mailbox password>
#   SMTP_FROM_EMAIL=info@emersoneims.com
# ═══════════════════════════════════════════════════════════════════
SMTP_HOST=mail.emersoneims.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@emersoneims.com
SMTP_PASSWORD=your-mailbox-password
SMTP_FROM_EMAIL=info@emersoneims.com
SMTP_FROM_NAME=EmersonEIMS Website Leads
# Team mailboxes that receive lead alerts (comma-separated).
LEAD_RECIPIENTS=info@emersoneims.com,sally@emersoneims.com

# ═══════════════════════════════════════════════════════════════════
# LEAD DELIVERY — where contact-form enquiries are actually sent
# The /api/contact route fires ALL configured channels. If NONE are set,
# the lead is logged as 🚨 LEAD NOT DELIVERED and the visitor is pushed to
# the WhatsApp fallback. Set at least ONE of the channels below in Vercel.
# ═══════════════════════════════════════════════════════════════════
# Sales inbox + line that alerts are routed to (defaults are the live business).
SALES_EMAIL=emersoneimservices@gmail.com
SALES_PHONE=+254768860665
# Public WhatsApp number used for the visitor click-to-chat deep link (digits only).
NEXT_PUBLIC_WHATSAPP_NUMBER=254768860665
#
# EASIEST ZERO-COST CHANNEL — a generic JSON webhook. Point this at a Google
# Apps Script web app (posts to your Gmail), a Zapier/Make hook, or a Slack/
# Discord incoming webhook. No paid API account required; leads arrive instantly.
LEAD_WEBHOOK_URL=
#
# Transactional email (requires a verified domain on resend.com).
RESEND_API_KEY=
#
# WhatsApp Business Cloud API (Meta) — for automated WhatsApp sales alerts.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ═══════════════════════════════════════════════════════════════════
# SMS GATEWAY - AFRICA'S TALKING (Popular in Kenya)
# https://africastalking.com/
# ═══════════════════════════════════════════════════════════════════
AFRICASTALKING_API_KEY=your-api-key
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=EMERSONEIMS

# Alternative: Twilio
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ═══════════════════════════════════════════════════════════════════
# AI/ML MODEL ENDPOINTS
# ═══════════════════════════════════════════════════════════════════
OPENAI_API_KEY=your-openai-api-key
REPLICATE_API_TOKEN=your-replicate-api-token

# ═══════════════════════════════════════════════════════════════════
# DATABASE (PostgreSQL - Required for Pro Building Suite)
# ═══════════════════════════════════════════════════════════════════
# Local Development:
DATABASE_URL=postgresql://postgres:password@localhost:5432/emersoneims_building

# Production (Supabase/Vercel Postgres/Railway):
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Alternative: MongoDB (not used by building suite)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/emersoneims

# ═══════════════════════════════════════════════════════════════════
# REAL DATA APIs (All free, no keys needed)
# ═══════════════════════════════════════════════════════════════════
# NASA POWER API - Solar irradiance & climate data
NASA_POWER_API_URL=https://power.larc.nasa.gov/api/temporal/daily/point

# Open-Elevation API - Terrain elevation
OPEN_ELEVATION_API_URL=https://api.open-elevation.com/api/v1/lookup

# ISRIC SoilGrids API - Soil composition data
SOILGRIDS_API_URL=https://rest.isric.org/soilgrids/v2.0/properties/query

# Open-Meteo API - Historical weather/precipitation
OPEN_METEO_API_URL=https://archive-api.open-meteo.com/v1/archive

# OpenStreetMap APIs - Water bodies, amenities, infrastructure
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
NOMINATIM_API_URL=https://nominatim.openstreetmap.org

# ═══════════════════════════════════════════════════════════════════
# AUTHENTICATION
# ═══════════════════════════════════════════════════════════════════
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=https://your-domain.com
